# Default: text files normalised to LF in the repo + working tree
* text=auto eol=lf

# Common text formats — explicit LF
*.md       text eol=lf
*.mdx      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.sql      text eol=lf
*.prisma   text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.rs       text eol=lf

# Windows-native scripts must be CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary — never normalise
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.woff     binary
*.woff2    binary
*.ttf      binary
